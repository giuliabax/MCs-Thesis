# LM Studio (default local provider) - no API key required.
# Start LM Studio, load the model, start the local server (Developer tab,
# default http://localhost:1234), then set LMSTUDIO_MODEL to the exact
# identifier LM Studio reports for the loaded model (see
# GET http://localhost:1234/v1/models or the server logs).
LMSTUDIO_MODEL=replace-with-the-lm-studio-model-identifier
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Groq (optional fallback provider) - only needed with llm.provider: groq.
# Never commit a real API key.
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=replace-with-a-groq-model-id
